{
  "title": "SmartRecs Platform — Control Plane & Operator",
  "uid": "smartrecs-platform-core",
  "schemaVersion": 38,
  "version": 1,
  "tags": ["smartrecs", "platform", "control-plane", "operator"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "tenant",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(platform_runs_active, tenant)",
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Active runs by tenant",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (tenant) (platform_runs_active{tenant=~\"$tenant\"})",
          "legendFormat": "{{tenant}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Admission rate by outcome",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (phase) (rate(platform_runs_admitted_total[5m]))",
          "legendFormat": "{{phase}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Admission latency (p50 / p95 / p99)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(platform_admission_latency_seconds_bucket[5m])))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(platform_admission_latency_seconds_bucket[5m])))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(platform_admission_latency_seconds_bucket[5m])))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 4,
      "title": "Reconcile latency p95 by kind",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (kind, le) (rate(platform_reconcile_latency_seconds_bucket[5m])))",
          "legendFormat": "{{kind}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 5,
      "title": "Audit-chain writes (errors should be zero)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 16, "w": 8, "h": 6 },
      "targets": [
        {
          "expr": "sum by (result) (rate(platform_audit_chain_writes_total[5m]))",
          "legendFormat": "{{result}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Admission error ratio (SLO panel)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 8, "y": 16, "w": 8, "h": 6 },
      "targets": [
        {
          "expr": "sum(rate(platform_runs_admitted_total{phase=~\"rejected_.*\"}[5m])) / sum(rate(platform_runs_admitted_total[5m]))",
          "legendFormat": "rejected fraction"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit" }
      }
    }
  ]
}
